# MediaOS environment configuration
# Copy this file to `.env.local` and fill in real values.
# The app boots without these (in a degraded "configure credentials" state),
# but research, AI generation, auth, and persistence require them.

# -----------------------------------------------------------------------------
# Supabase (Postgres + Auth + Storage)
# Project Settings -> API
# -----------------------------------------------------------------------------
# Public project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# Public anon key (safe to expose to the browser; RLS protects data)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key (SERVER ONLY - bypasses RLS; never expose to the client)
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Azure AI Foundry (chat/reasoning/copy + image visuals)
# This is the Azure AI Foundry OpenAI-COMPATIBLE v1 surface
# (https://<resource>.services.ai.azure.com/openai/v1) - NOT classic
# Azure OpenAI (*.openai.azure.com + deployment + api-version). Chat is called
# via the OpenAI SDK (responses.create / chat completions) using base_url +
# api_key; image generation POSTs to the images/generations endpoint and
# returns data[0].b64_json (png). See Docs/azure-models.md for full details.
# Azure AI Foundry portal -> your project -> Models + Keys and Endpoint.
# -----------------------------------------------------------------------------
# Resource endpoint, e.g. https://my-resource.services.ai.azure.com
AZURE_OPENAI_ENDPOINT=
# Azure AI Foundry API key (shared by chat + image; rotate periodically)
AZURE_OPENAI_API_KEY=
# OpenAI-compatible v1 base URL, e.g. https://my-resource.services.ai.azure.com/openai/v1
AZURE_OPENAI_BASE_URL=
# Deployment name for the chat/reasoning model (kept as *_GPT4O_DEPLOYMENT for
# backward compat with existing code that reads it), e.g. gpt-5.3-chat
AZURE_OPENAI_GPT4O_DEPLOYMENT=
# Same chat deployment under the v1-aligned key name, e.g. gpt-5.3-chat
AZURE_OPENAI_CHAT_DEPLOYMENT=
# Deployment name for the image model, e.g. MAI-Image-2.5
AZURE_OPENAI_IMAGE_DEPLOYMENT=
# Full image generations endpoint (returns data[0].b64_json),
# e.g. https://my-resource.services.ai.azure.com/openai/v1/images/generations
AZURE_OPENAI_IMAGE_ENDPOINT=
# API version for the v1 surface (use "preview")
AZURE_OPENAI_API_VERSION=preview
# Project endpoint for the responses API,
# e.g. https://my-resource.services.ai.azure.com/api/projects/<project-name>
AZURE_AI_PROJECT_ENDPOINT=

# -----------------------------------------------------------------------------
# Bright Data MCP (live audience research: SERP + scraping + structured data)
# -----------------------------------------------------------------------------
BRIGHTDATA_API_TOKEN=
# Optional: Web Unlocker zone used for scraping (defaults to "mcp_unlocker")
BRIGHTDATA_WEB_UNLOCKER_ZONE=
# Optional: dedicated SERP zone for search; falls back to the Web Unlocker zone.
# Example/default: serp_api1 (a dedicated Bright Data SERP API zone).
BRIGHTDATA_SERP_ZONE=
# Optional: Bright Data Scraping Browser WSS endpoint for Puppeteer/Playwright
# (interactive / JS-heavy pages). Format: wss://USER:PASS@brd.superproxy.io:9222
BRIGHTDATA_BROWSER_WS=
