# MediaOS environment configuration
# Copy this file to `.env.local` and fill in real values.
# The app boots without these (in a degraded "configure credentials" state),
# but research, AI generation, auth, and persistence require them.

# -----------------------------------------------------------------------------
# Supabase (Postgres + Auth + Storage)
# Project Settings -> API
# -----------------------------------------------------------------------------
# Public project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# Public anon key (safe to expose to the browser; RLS protects data)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key (SERVER ONLY - bypasses RLS; never expose to the client)
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Azure OpenAI (GPT-4o for reasoning/copy, GPT-Image for visuals)
# Azure Portal -> your Azure OpenAI resource -> Keys and Endpoint
# -----------------------------------------------------------------------------
# Resource endpoint, e.g. https://my-resource.openai.azure.com
AZURE_OPENAI_ENDPOINT=
# Azure OpenAI API key
AZURE_OPENAI_API_KEY=
# Deployment name for the GPT-4o (chat/reasoning) model
AZURE_OPENAI_GPT4O_DEPLOYMENT=gpt-4o
# Deployment name for the image model (gpt-image-1 / gpt-image-2)
AZURE_OPENAI_IMAGE_DEPLOYMENT=gpt-image-2
# API version. Chat works on the GA version below; image generation may require
# a preview version (e.g. 2025-04-01-preview) depending on your deployment.
AZURE_OPENAI_API_VERSION=2024-10-21

# -----------------------------------------------------------------------------
# Bright Data MCP (live audience research: SERP + scraping + structured data)
# -----------------------------------------------------------------------------
BRIGHTDATA_API_TOKEN=
